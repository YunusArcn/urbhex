# Bu dosyayı .env olarak kopyalayıp doldurun. .env ASLA commit edilmez.
# GERÇEK ANAHTARLARI BU DOSYAYA YAZMAYIN — bu dosya git'e girer!
SUPABASE_URL=https://XXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key — sadece botta, frontend'e ASLA koymayın

# AI sağlayıcıları — öncelik: Gemini ↔ Groq (ÜCRETSİZ, dönüşümlü) → Claude (yedek)
GEMINI_API_KEY=AIza...        # aistudio.google.com/apikey (ücretsiz, kart istemez)
GROQ_API_KEY=gsk_...          # console.groq.com/keys (ücretsiz)
ANTHROPIC_API_KEY=sk-ant-...  # son çare yedek (isteğe bağlı)

# Güvenlik Alarmı e-postaları (isteğe bağlı — boşsa sadece uygulama içi bildirim)
# Gmail: Google Hesap > Güvenlik > 2 Adımlı Doğrulama > Uygulama şifreleri
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=adresin@gmail.com
SMTP_PASS=uygulama-sifresi
SMTP_FROM=Urbhex Alarm <adresin@gmail.com>
